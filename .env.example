# Optional: Custom RPC endpoint (defaults to public Solana mainnet)
# For better rate limits, use a private RPC like QuickNode, Helius, or Alchemy
NEXT_PUBLIC_RPC_ENDPOINT=https://api.mainnet-beta.solana.com

# Treasury address — dust tokens are transferred here when users recover dust
NEXT_PUBLIC_TREASURY_ADDRESS=YOUR_SOLANA_ADDRESS_HERE
